{
  "name": "civicpulse",
  "private": true,
  "main": "expo-router/entry",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "api:dev": "npm run start:dev --workspace=@civicpulse/api",
    "api:build": "npm run build --workspace=@civicpulse/api",
    "mobile:start": "npx expo start --clear --offline",
    "mobile:web": "npx expo start --web --clear --offline",
    "db:generate": "npm run prisma:generate --workspace=@civicpulse/api",
    "db:migrate": "npm run prisma:migrate --workspace=@civicpulse/api",
    "db:seed": "npm run prisma:seed --workspace=@civicpulse/api"
  },
  "dependencies": {
    "expo": "^54.0.0",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/react": "^19.2.17"
  }
}
